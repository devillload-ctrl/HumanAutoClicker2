<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🤖 Human Auto Clicker v2"
            android:textColor="#e94560"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="16dp"/>

        <!-- Status -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="● หยุด"
            android:textColor="#888888"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingBottom="8dp"/>

        <!-- Accessibility Permission Card -->
        <LinearLayout
            android:id="@+id/cardPermission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#c1121f"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠️ ต้องเปิด Accessibility Service ก่อน"
                android:textColor="#ffffff"
                android:textStyle="bold"
                android:textSize="13sp"/>

            <Button
                android:id="@+id/btnPermission"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="เปิดการตั้งค่า Accessibility"
                android:backgroundTint="#ffffff"
                android:textColor="#c1121f"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Overlay Permission Card -->
        <LinearLayout
            android:id="@+id/cardOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#533483"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠️ ต้องอนุญาตแสดงทับหน้าจอ"
                android:textColor="#ffffff"
                android:textStyle="bold"
                android:textSize="13sp"/>

            <Button
                android:id="@+id/btnOverlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="อนุญาตแสดงทับหน้าจอ"
                android:backgroundTint="#ffffff"
                android:textColor="#533483"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Target Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎯 เป้าหมาย (X, Y)"
            android:textColor="#e94560"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#0f3460"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etX"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="X"
                    android:inputType="number"
                    android:textColor="#eaeaea"
                    android:textColorHint="#8892a4"
                    android:backgroundTint="#533483"
                    android:layout_marginEnd="8dp"/>

                <EditText
                    android:id="@+id/etY"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Y"
                    android:inputType="number"
                    android:textColor="#eaeaea"
                    android:textColorHint="#8892a4"
                    android:backgroundTint="#533483"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btnAddTarget"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="➕ เพิ่ม"
                    android:backgroundTint="#2d6a4f"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btnPickTarget"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="👆 แตะเลือก"
                    android:backgroundTint="#533483"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btnClearTargets"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🗑️ ล้าง"
                    android:backgroundTint="#c1121f"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvTargetList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ยังไม่มีเป้าหมาย"
                android:textColor="#8892a4"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Interval Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏱️ ช่วงเวลา (วินาที)"
            android:textColor="#e94560"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#0f3460"
            android:orientation="horizontal"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ต่ำสุด:"
                android:textColor="#eaeaea"
                android:layout_gravity="center_vertical"/>

            <EditText
                android:id="@+id/etIntervalMin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1.0"
                android:inputType="numberDecimal"
                android:textColor="#eaeaea"
                android:backgroundTint="#533483"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="สูงสุด:"
                android:textColor="#eaeaea"
                android:layout_gravity="center_vertical"/>

            <EditText
                android:id="@+id/etIntervalMax"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="3.0"
                android:inputType="numberDecimal"
                android:textColor="#eaeaea"
                android:backgroundTint="#533483"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Long Break Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="😴 พักยาวแบบสุ่ม"
            android:textColor="#e94560"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#0f3460"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/cbLongBreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="เปิดพักยาว"
                    android:textColor="#eaeaea"
                    android:buttonTint="#e94560"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="พัก:"
                    android:textColor="#eaeaea"
                    android:layout_gravity="center_vertical"/>

                <EditText
                    android:id="@+id/etBreakMin"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="3"
                    android:inputType="number"
                    android:textColor="#eaeaea"
                    android:backgroundTint="#533483"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="~"
                    android:textColor="#8892a4"
                    android:layout_gravity="center_vertical"/>

                <EditText
                    android:id="@+id/etBreakMax"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="60"
                    android:inputType="number"
                    android:textColor="#eaeaea"
                    android:backgroundTint="#533483"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="นาที"
                    android:textColor="#8892a4"
                    android:layout_gravity="center_vertical"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="โอกาส:"
                    android:textColor="#eaeaea"
                    android:layout_gravity="center_vertical"/>

                <EditText
                    android:id="@+id/etBreakChance"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="10"
                    android:inputType="number"
                    android:textColor="#eaeaea"
                    android:backgroundTint="#533483"
                    android:layout_marginStart="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="% ต่อรอบ"
                    android:textColor="#8892a4"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Behavior Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🧠 พฤติกรรมมนุษย์"
            android:textColor="#e94560"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#0f3460"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ความไม่แม่นยำ (px)"
                android:textColor="#eaeaea"
                android:textSize="12sp"/>
            <SeekBar
                android:id="@+id/seekJitter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="30"
                android:progress="5"
                android:progressTint="#e94560"
                android:thumbTint="#e94560"/>
            <TextView
                android:id="@+id/tvJitter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="5 px"
                android:textColor="#00b4d8"
                android:textSize="11sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="คลิกเดี่ยว %"
                android:textColor="#eaeaea"
                android:textSize="12sp"/>
            <SeekBar
                android:id="@+id/seekSingle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="60"
                android:progressTint="#e94560"
                android:thumbTint="#e94560"/>
            <TextView
                android:id="@+id/tvSingle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="60%"
                android:textColor="#00b4d8"
                android:textSize="11sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="กดค้างสั้น %"
                android:textColor="#eaeaea"
                android:textSize="12sp"/>
            <SeekBar
                android:id="@+id/seekHold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="30"
                android:progressTint="#e94560"
                android:thumbTint="#e94560"/>
            <TextView
                android:id="@+id/tvHold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="30%"
                android:textColor="#00b4d8"
                android:textSize="11sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="กดค้างนาน %"
                android:textColor="#eaeaea"
                android:textSize="12sp"/>
            <SeekBar
                android:id="@+id/seekLong"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="10"
                android:progressTint="#e94560"
                android:thumbTint="#e94560"/>
            <TextView
                android:id="@+id/tvLong"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="10%"
                android:textColor="#00b4d8"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- Max Clicks -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🛑 หยุดเมื่อครบ (0 = ไม่จำกัด)"
            android:textColor="#e94560"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingBottom="6dp"/>

        <EditText
            android:id="@+id/etMaxClicks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0"
            android:inputType="number"
            android:textColor="#eaeaea"
            android:backgroundTint="#533483"
            android:layout_marginBottom="16dp"/>

        <!-- Control Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnStart"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="▶ เริ่ม"
                android:backgroundTint="#2d6a4f"
                android:textSize="16sp"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btnStop"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⏹ หยุด"
                android:backgroundTint="#c1121f"
                android:textSize="16sp"/>
        </LinearLayout>

        <!-- Click Count -->
        <TextView
            android:id="@+id/tvClickCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="คลิกทั้งหมด: 0"
            android:textColor="#00b4d8"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingBottom="16dp"/>

    </LinearLayout>
</ScrollView>
